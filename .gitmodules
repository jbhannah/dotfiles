[submodule ".zprezto"]
	path = common/.zprezto
	url = https://github.com/sorin-ionescu/prezto.git
[submodule ".tmux"]
	path = common/.tmux
	url = https://github.com/gpakosz/.tmux.git
[submodule ".emacs.d"]
	branch = develop
	path = common/.emacs.d
	url = https://github.com/syl20bnr/spacemacs.git
[submodule ".vim/bundle/repos/github.com/Shougo/dein.vim"]
	path = common/.vim/bundle/repos/github.com/Shougo/dein.vim
	url = https://github.com/Shougo/dein.vim.git
[submodule ".fubectl"]
	path = common/.fubectl
	url = https://github.com/kubermatic/fubectl.git
[submodule "common/.config/fish/fisher"]
	path = common/.config/fish/fisher
	url = https://github.com/jorgebucaran/fisher.git
