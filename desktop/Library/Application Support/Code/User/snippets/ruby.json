{
	// Place your snippets for ruby here. Each snippet is defined under a snippet name and has a prefix, body and
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }
	"do block": {
		"prefix": "do",
		"body": [
			"do",
			"  $0",
			"end"
		],
		"description": "Insert a do block"
	},
	"do block with parameter": {
		"prefix": "dop",
		"body": [
			"do |${1:param}|",
			"  $0",
			"end"
		],
		"description": "Insert a do block with parameter"
	}
}
