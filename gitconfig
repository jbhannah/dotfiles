	email = jesse@jbhannah.net
	signingkey = 17BAAFA4
[core]
	autocrlf = input
	excludesfile = ~/.gitignore
[push]
	default = simple
[credential]
	helper = osxkeychain
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[filter "hawser"]
	clean = git hawser clean %f
	smudge = git hawser smudge %f
	required = true
[filter "lfs"]
	clean = git-lfs clean %f
	smudge = git-lfs smudge %f
	required = true
[filter "media"]
	clean = git media clean %f
	smudge = git media smudge %f
	required = true
[include]
	path = .gitconfig.local
