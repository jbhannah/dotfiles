[user]
	name = Jesse B. Hannah
	email = jesse@jbhannah.net
[core]
	autocrlf = input
	excludesfile = ~/.gitignore
[push]
	default = simple
[include]
	path = .gitconfig.local
[credential]
	helper = osxkeychain
[filter "media"]
	clean = git media clean %f
	smudge = git media smudge %f
	required = true
[init]
	templatedir = ~/.git_template
[filter "hawser"]
	clean = git hawser clean %f
	smudge = git hawser smudge %f
	required = true
