#!/bin/sh
if [ -d $HOME/.zprezto/.git ]; then
  echo "Updating Prezto...\c"
  ( cd $HOME/.zprezto && git pull && git submodule update --init --recursive ) &> /dev/null
  echo "done!"
else
  if [ ! -d $HOME/.zprezto ]; then
    echo "Installing Prezto...\c"
    ( git clone https://github.com/sorin-ionescu/prezto.git $HOME/.zprezto && ( cd $HOME/.zprezto && git submodule update --init --recursive ) ) &> /dev/null
    echo "done!"
  fi
fi

if [ -d $HOME/.config/base16-shell/.git ]; then
  echo "Updating Base16 Shell...\c"
  ( cd $HOME/.config/base16-shell && git pull ) &> /dev/null
  echo "done!"
else
  if [ ! -d $HOME/.config/base16-shell ]; then
    echo "Installing Base16 Shell...\c"
    ( git clone https://github.com/chriskempson/base16-shell.git $HOME/.config/base16-shell ) &> /dev/null
    echo "done!"
  fi
fi

if [ ! -d $HOME/.vim/bundle/neobundle.vim ]; then
  echo "Installing NeoBundle...\c"
  ( git clone https://github.com/Shougo/neobundle.vim.git $HOME/.vim/bundle/neobundle.vim ) &> /dev/null
  echo "done!"
fi

echo "Updating Vim plugins...\c"
vim -u $HOME/.vimrc.bundles -e -s +NeoBundleInstall! +NeoBundleClean! +qa
echo "done!"
