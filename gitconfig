[init]
	templatedir = ~/.git_template
[user]
	name = Jesse B. Hannah
	email = jesse@jbhannah.net
[core]
	autocrlf = input
	excludesfile = ~/.gitignore
[push]
	default = simple
[credential]
	helper = osxkeychain
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red bold
	new = green bold
[color "status"]
	added = yellow
	changed = green
	untracked = cyan
[filter "hawser"]
	clean = git hawser clean %f
	smudge = git hawser smudge %f
	required = true
[filter "media"]
	clean = git media clean %f
	smudge = git media smudge %f
	required = true
[include]
	path = .gitconfig.local
